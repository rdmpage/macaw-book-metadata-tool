# Macaw Docker Environment Configuration
# Copy this file to .env and fill in your values.
# All settings are optional — sensible defaults are used if not set.

# ----- Web Server -----
# Port to expose Macaw on (default 8888 for local dev, use 80 for production)
APP_PORT=8888

# ----- Database -----
DB_HOST=db
DB_NAME=macaw
DB_USER=macaw
DB_PASS=macaw
DB_PORT=3306

# MySQL root password (used to initialise the database container)
MYSQL_ROOT_PASSWORD=macaw_root

# ----- Organisation -----
MACAW_ADMIN_EMAIL=
MACAW_ORG_NAME=

# ----- SMTP (for QA emails and error notifications) -----
MACAW_SMTP_HOST=
MACAW_SMTP_PORT=25
MACAW_SMTP_USER=
MACAW_SMTP_PASS=

# ----- BHL -----
MACAW_BHL_API_KEY=

# ----- Internet Archive -----
MACAW_IA_ACCESS_KEY=
MACAW_IA_SECRET=
MACAW_IA_EMAIL=
MACAW_IA_PASSWORD=

# ----- Export Modules -----
# Comma-separated list, case-sensitive to plugin filename, e.g. Internet_archive
MACAW_EXPORT_MODULES=
